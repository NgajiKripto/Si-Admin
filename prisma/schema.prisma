generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model BusinessProfile {
  id          String          @id @default(cuid())
  name        String
  type        String
  description String?
  settings    String?
  channels    Channel[]
  categories  StockCategory[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Channel {
  id            String          @id @default(cuid())
  name          String
  type          String
  isActive      Boolean         @default(true)
  config        String?
  businessId    String
  business      BusinessProfile @relation(fields: [businessId], references: [id])
  conversations Conversation[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Customer {
  id            String         @id @default(cuid())
  name          String
  phone         String?
  email         String?
  channel       String?
  notes         String?
  conversations Conversation[]
  followUps     FollowUp[]
  feedbacks     Feedback[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Conversation {
  id            String    @id @default(cuid())
  customerId    String
  customer      Customer  @relation(fields: [customerId], references: [id])
  channelId     String
  channelRef    Channel   @relation(fields: [channelId], references: [id])
  status        String    @default("ACTIVE")
  lastMessage   String?
  lastMessageAt DateTime?
  unreadCount   Int       @default(0)
  messages      Message[]
  feedbacks     Feedback[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

/// sender field uses: "ADMIN" | "CUSTOMER"
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  content        String
  sender         String
  sentAt         DateTime     @default(now())
  isRead         Boolean      @default(false)
}

/// status field uses: "PENDING" | "DONE" | "OVERDUE"
model FollowUp {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  title       String
  description String?
  dueDate     DateTime
  status      String   @default("PENDING")
  priority    String   @default("MEDIUM")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Feedback {
  id             String        @id @default(cuid())
  customerId     String
  customer       Customer      @relation(fields: [customerId], references: [id])
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  content        String
  rating         Int
  templateUsed   String?
  sentAt         DateTime      @default(now())
}

model StockCategory {
  id          String          @id @default(cuid())
  name        String
  description String?
  businessId  String
  business    BusinessProfile @relation(fields: [businessId], references: [id])
  items       StockItem[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model StockItem {
  id            String          @id @default(cuid())
  name          String
  sku           String          @unique
  categoryId    String
  category      StockCategory   @relation(fields: [categoryId], references: [id])
  quantity      Int             @default(0)
  minThreshold  Int             @default(5)
  unit          String          @default("pcs")
  price         Float           @default(0)
  lastRestocked DateTime?
  movements     StockMovement[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

/// type field uses: "IN" | "OUT"
model StockMovement {
  id          String    @id @default(cuid())
  stockItemId String
  stockItem   StockItem @relation(fields: [stockItemId], references: [id])
  type        String
  quantity    Int
  notes       String?
  createdAt   DateTime  @default(now())
}

model FeedbackTemplate {
  id        String   @id @default(cuid())
  name      String
  content   String
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// category field uses: "CHAT_HISTORY" | "FAQ" | "PRODUCT_INFO" | "SOP" | "RESPONSE_TEMPLATE" | "TONE_GUIDELINE"
model KnowledgeEntry {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String
  tags      String?
  source    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// tier field uses: "WORKING" | "EPISODIC" | "SEMANTIC" | "PROCEDURAL"
model AgentMemory {
  id             String   @id @default(cuid())
  tier           String
  content        String
  context        String?
  strength       Float    @default(1.0)
  accessCount    Int      @default(0)
  lastAccessedAt DateTime @default(now())
  decayFactor    Float    @default(1.0)
  metadata       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/// type field uses: "PATTERN" | "IMPROVEMENT" | "SUGGESTION" | "CORRECTION"
model LearningInsight {
  id         String    @id @default(cuid())
  type       String
  content    String
  source     String?
  confidence Float     @default(0.5)
  applied    Boolean   @default(false)
  appliedAt  DateTime?
  impact     String?
  createdAt  DateTime  @default(now())
}

/// type field uses: "CUSTOMER" | "PRODUCT" | "ISSUE" | "SOLUTION" | "TOPIC"
model KnowledgeGraphEntity {
  id            String                   @id @default(cuid())
  name          String
  type          String
  properties    String?
  fromRelations KnowledgeGraphRelation[] @relation("FromEntity")
  toRelations   KnowledgeGraphRelation[] @relation("ToEntity")
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
}

model KnowledgeGraphRelation {
  id           String               @id @default(cuid())
  fromEntityId String
  fromEntity   KnowledgeGraphEntity @relation("FromEntity", fields: [fromEntityId], references: [id])
  toEntityId   String
  toEntity     KnowledgeGraphEntity @relation("ToEntity", fields: [toEntityId], references: [id])
  relationType String
  weight       Float                @default(1.0)
  metadata     String?
  createdAt    DateTime             @default(now())
}

model AgentGuardConfig {
  id                    String   @id @default(cuid())
  isEnabled             Boolean  @default(true)
  maxResponseLength     Int      @default(500)
  maxResponseTokens     Int      @default(200)
  allowedTopics         String   @default("[\"produk\",\"harga\",\"pengiriman\",\"pembayaran\",\"keluhan\",\"retur\",\"promo\",\"jam_operasional\",\"stok\",\"garansi\"]")
  blockedPatterns       String   @default("[\"ignore previous\",\"abaikan instruksi\",\"you are now\",\"kamu sekarang adalah\",\"forget everything\",\"lupakan semua\",\"system:\",\"\\\\[SYSTEM\\\\]\",\"jailbreak\",\"DAN mode\"]")
  blockedOutputPatterns String   @default("[\"system prompt\",\"instruksi sistem\",\"you are an AI\",\"saya adalah AI\"]")
  responseFormat        String   @default("text")
  systemPromptHash      String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
